# Exoplanet Intelligence — Variables de entorno
# Copiar este archivo como .env y reemplazar los valores
#   cp .env.example .env

# NASA Exoplanet Archive (opcional — la API TAP no requiere key para datos públicos)
NASA_API_KEY=TU_NASA_KEY

# Groq — para el agente IA (Llama 3.3 70B)
# Obtener en: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
